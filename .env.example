# Configuración de Supabase
# Copia este archivo a un nuevo archivo llamado .env y completa los valores.
# Puedes encontrar estos valores en el panel de configuración de tu proyecto en Supabase (Settings -> API).

VITE_SUPABASE_URL=tu_url_de_supabase_aqui
VITE_SUPABASE_KEY=tu_anon_public_key_de_supabase_aqui
